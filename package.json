{
  "name": "haneulchi",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual:qa": "vitest run src/App.test.tsx --testNamePattern \"visual QA route|dynamic visual QA|concept asset filename aliases\"",
    "preview": "vite preview",
    "tauri": "tauri",
    "release:macos:app": "tauri build --bundles app",
    "release:macos:dmg": "tauri build --bundles dmg",
    "release:macos:verify": "bash scripts/release/verify-macos-artifacts.sh",
    "release:macos:notarize": "bash scripts/release/notarize-macos.sh",
    "release:update-feed:verify": "bash scripts/release/verify-update-feed.sh",
    "release:homebrew:cask": "bash scripts/release/render-homebrew-cask.sh",
    "release:symbols:upload": "bash scripts/release/upload-symbols.sh"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "codemirror": "^6.0.2",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "dompurify": "3.4.2"
  }
}
